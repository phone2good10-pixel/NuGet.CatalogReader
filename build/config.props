<Project ToolsVersion="15.0">
  <!-- Dependency versions -->
  <PropertyGroup>
    <NuGetPackageVersion>7.3.0</NuGetPackageVersion>
    <CommandLineUtilsVersion>5.0.1</CommandLineUtilsVersion>
    <NuGetTestHelpersVersion>2.1.38</NuGetTestHelpersVersion>
    <SleetVersion>7.1.0</SleetVersion>
    <JsonVersion>13.0.4</JsonVersion>
  </PropertyGroup>

  <!-- Config -->
  <PropertyGroup>
    <RepositoryName>NuGet.CatalogReader</RepositoryName>
    <PackageIconPath>$(MSBuildThisFileDirectory)/icons/icon.png</PackageIconPath>
  </PropertyGroup>

  <!-- Nuspec defaults -->
  <PropertyGroup>
    <Authors>emgarten</Authors>
    <ProjectUrl>https://github.com/emgarten/nuget.catalogreader</ProjectUrl>
    <RepositoryType>git</RepositoryType>
    <RepositoryUrl>https://github.com/emgarten/nuget.catalogreader</RepositoryUrl>
    <PackageTags>nuget nugetcatalog nugetfeed nugetv3</PackageTags>
    <PackageIconUrl>https://emgartenstatic.blob.core.windows.net/nupkgs/icons/nuget.catalogreader.png</PackageIconUrl>
  </PropertyGroup>

  <PropertyGroup>
    <NoWarn>$(NoWarn)</NoWarn>
  </PropertyGroup>

  <!-- Analyzers -->
  <PropertyGroup>
    <AnalysisMode>Recommended</AnalysisMode>
    <NoWarn>$(NoWarn);CA2211;CA1308;CA2007;CA1051</NoWarn>
  </PropertyGroup>
</Project>